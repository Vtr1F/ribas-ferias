CREATE TABLE notifications (
    id SERIAL PRIMARY KEY,
    user_id INTEGER REFERENCES users(id) ON DELETE CASCADE,
    mensagem TEXT NOT NULL,
    lida BOOLEAN DEFAULT FALSE,
    link_pedido INTEGER REFERENCES requests(id) ON DELETE SET NULL, -- Opcional: clica e vai ao pedido
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);
CREATE TABLE audit_log (
    id SERIAL PRIMARY KEY,
    admin_id INTEGER REFERENCES users(id),
    request_id INTEGER REFERENCES requests(id) ON DELETE SET NULL,
    acao TEXT NOT NULL, -- Ex: 'APROVOU_FERIAS'
    detalhes JSONB, -- Podes guardar o estado antigo e o novo aqui
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);
CREATE TABLE company_settings (
    id SERIAL PRIMARY KEY,
    chave TEXT UNIQUE NOT NULL, -- Ex: 'dias_padrao'
    valor TEXT NOT NULL,       -- Ex: '22'
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);
